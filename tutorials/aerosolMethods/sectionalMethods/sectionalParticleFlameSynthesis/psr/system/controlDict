FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     mmcPbeFoam;

startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         1e-6;

deltaT          1e-7;

writeControl    runTime;

writeInterval   0.5;

writeFormat     ascii;

writePrecision  8;

writeCompression off;

timeFormat      fixed;

timePrecision   7;

runTimeModifiable yes;

adjustTimeStep  no;

maxCo           1;

graphFormat    xmgr;

libs ( 
        "libOpenFOAM.so"
        "libsampling.so"
        "libfieldFunctionObjects.so"
        "libsimpleSwakFunctionObjects.so"
        "libswakFunctionObjects.so"
        "libgroovyBC.so"
     );

functions
{
}

