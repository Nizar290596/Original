FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      funkySetFieldsDict;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

expressions
(
    H
    {
        field H;

        expression "species(Temperature)";

        variables
        2
        (
        "r=sqrt(sqr(pos().x)+sqr(pos().y));"
        "Temperature=temperature(r);"
        )
        ;

        lookuptables
        (
            {
                name            temperature;
                fileName        "$FOAM_CASE/constant/boundaryData/radialTemperatureProfile.dat";
                outOfBounds     clamp;
            }
            {
                name            species;
                fileName        "$FOAM_CASE/constant/boundaryData/radialH.dat";
                outOfBounds     clamp;
            }
        );

        keepPatches 1;
    }

