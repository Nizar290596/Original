FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application      mmcFoam;

startFrom     latestTime;

startTime              0;

stopAt           endTime;

endTime            2e-06;

deltaT             1e-06;

writeControl    timeStep;

writeInterval          5;

writeFormat        ascii;

writePrecision        10;

writeCompression     off;

timeFormat         fixed;

timePrecision          6;

runTimeModifiable    yes;

adjustTimeStep        no;

libs 
( 
    "libOpenFOAM.so"
    "libsampling.so"
);

functions
{
    fieldAverage
    {
        enabled                 false;

        resetOnRestart          false;

        type             fieldAverage;

        writeControl       outputTime;

        fields
        (
            U
            {
                mean               on;
                prime2Mean         on;
                base             time;
            }

            f
            {
                mean               on;
                prime2Mean         on;
                base             time;
            }

            T
            {
                mean               on;
                prime2Mean         on;
                base             time;
            }
        
            rho
            {
                mean               on;
                prime2Mean         on;
                base             time;
            }

            muSgs
            {
                mean               on;
                prime2Mean         on;
                base             time;
            }

            nu
            {
                mean               on;
                prime2Mean         on;
                base             time;
            }

            nut
            {
                mean               on;
                prime2Mean         on;
                base             time;
            }

            epsilon
            {
                mean               on;
                prime2Mean         on;
                base             time;
            }

            k
            {
                mean               on;
                prime2Mean         on;
                base             time;
            }
        );
    }

