FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      sampleDict;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

setFormat             raw;
surfaceFormat         raw;

interpolationScheme cellPointFace;

fields
(
    OHAv    
    SIOAv
    //SIO-2Av
    //SIO-3Av
    SIO2Av
