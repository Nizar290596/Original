(
    centerline
    {
        type        midPoint;
        axis        z;

        start       ( 0 0 0    );
        end         ( 0 0 0.1828 );
    }

    nozzleline
    {
        type        midPoint;
        axis        z;

        start       ( 0 0.002285 0.00 );
        end         ( 0 0.002285 0.1828 );
    }

    zD00
    {
        type        midPoint;
        axis        y;

        start       ( 0  0      1e-08 );
        end         ( 0  0.0457 1e-08 );
    }

    zD01
    {
        type        midPoint;
        axis        y;

        start       ( 0  0      0.00457 );
        end         ( 0  0.0457 0.00457 );
    }

    zD05
