        type        midPoint;
        axis        y;

        start       ( 0  0      0.06855 );
        end         ( 0  0.0457 0.06855 );
    }

    zD20
    {
        type        midPoint;
        axis        y;

        start       ( 0  0      0.09140 );
        end         ( 0  0.0457 0.09140 );
    }

