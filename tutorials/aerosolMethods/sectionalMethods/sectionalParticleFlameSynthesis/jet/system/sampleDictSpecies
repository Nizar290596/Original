        type        midPoint;
        axis        y;

        start       ( 0  0      0.02285 );
        end         ( 0  0.0457 0.02285 );
    }
    
    zD10
    {
        type        midPoint;
        axis        y;

        start       ( 0  0      0.04570 );
        end         ( 0  0.0457 0.04570 );
    }

    zD15
