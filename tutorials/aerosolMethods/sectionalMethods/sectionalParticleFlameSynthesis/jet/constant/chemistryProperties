FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      chemistryProperties;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

chemistryType
{
    chemistrySolver   ode;
    chemistryThermo   psi;
}

chemistry             true;

initialChemicalTimeStep 1e-12;

odeCoeffs
{
    solver          seulex;
    absTol          1e-08;
    relTol          1e-02;
}

reduction
{
    active          off;
    method          pNone;;
}

tabulation
{
    active          off;
    method          pNone;
}

