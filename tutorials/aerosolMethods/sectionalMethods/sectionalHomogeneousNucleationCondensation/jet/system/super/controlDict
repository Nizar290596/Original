FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     pbeMmcFoam;

startFrom       startTime;

startTime       0;

stopAt          writeNow;

endTime		 	1;

deltaT          2e-06;

writeControl	adjustableRunTime;

writeInterval   0.01;

writeFormat     ascii;

writePrecision  6;

writeCompression off;

timeFormat      fixed;

timePrecision   6;

runTimeModifiable yes;

adjustTimeStep  no;

maxCo           0.6;

graphFormat	xmgr;

libs ( 
		"libOpenFOAM.so"
//		"libtimeLeft.so" 
		"libcompressibleDynamicSmagorinskyModel.so" 
		"libsimpleSwakFunctionObjects.so"
      	"libswakFunctionObjects.so"
      	"libgroovyBC.so"
	 );

functions
{
  	probes
    {
        type            probes;
        functionObjectLibs ("libsampling.so");
        enabled         true;
        outputControl   timeStep;
        outputInterval  1;

        fields
        (
			U
        );

        probeLocations
        (
            ( 0 0 0.00000 )
            ( 0 0 0.00235 )
            ( 0 0 0.00470 )
            ( 0 0 0.00705 )
            ( 0 0 0.00940 )
            ( 0 0 0.01175 )
            ( 0 0 0.01410 )
			( 0 0 0.01645 )
			( 0 0 0.01880 )
			( 0 0 0.02115 )
			( 0 0 0.02350 )
        );
    }

