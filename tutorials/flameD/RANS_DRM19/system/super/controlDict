FoamFile
{
    version         2.0;
    format          ascii;

    root            "";
    case            "";
    instance        "";
    local           "";

    class           dictionary;
    object          controlDict;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

applicationClass reactingFoam;

//startFrom       startTime;
startFrom       latestTime;

startTime       0;

stopAt          endTime;

endTime        75e-3;

deltaT         2e-5;

writeControl    adjustableRunTime;

writeInterval    5.0e-3;

//cycleWrite      0;

writeFormat     ascii;
//writeFormat     binary;

writePrecision  10;

writeCompression uncompressed;

timeFormat      general;

timePrecision   6;

runTimeModifiable yes;

//adjustTimeStep no;
adjustTimeStep yes;

maxCo          0.8;

//maxDeltaT      0.03;

