FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSchemes;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

ddtSchemes
{
    default Euler;
}

gradSchemes
{
    default         Gauss linear;
    grad(p)         Gauss linear;
}

divSchemes
{
    default          none;
    div(phi,rho)     Gauss upwind;
    div(phi,U)       Gauss upwind;
    div(phiU,p)      Gauss upwind;
    div(phi,k)       Gauss upwind;
    div(phi,epsilon) Gauss upwind;
    div(phi,Yi_h)    Gauss  upwind;
    div((phi|interpolate(rho)),p) Gauss upwind;
    div(phi,fu_ft_h) Gauss multivariateSelection 
    {
        fu              limitedLinear 1;
        ft              limitedLinear 1;
        h               limitedLinear 1;
    };

    div((muEff*grad(U).T()))			    	Gauss   linear;
    div((muEff*dev2(grad(U).T()))) 			Gauss linear;
    div((muEff*dev2(T(grad(U))))) 	Gauss linear;

     div(phi,f)      Gauss limitedLinear 1.0;
     div(phi,K)       Gauss upwind;
}

laplacianSchemes
{
    default                 Gauss linear corrected;
/*
    laplacian(muEff,U)      Gauss linear corrected;
    laplacian(muEff,ft)     Gauss linear limited 0.5;
    laplacian(muEff,fu)     Gauss linear limited 0.5;
    laplacian(((alphah*mut)+alpha),h) Gauss linear limited 0.5;
    laplacian((rho|A(U)),p) Gauss linear limited 0.5;
    laplacian(rhoD,k)       Gauss linear limited 0.5;
    laplacian(rhoD,epsilon) Gauss linear limited 0.5;
*/
}

interpolationSchemes
{
    default         linear;
    interpolate(HbyA) linear;
}

snGradSchemes
{
    default         corrected;
}

fluxRequired
{
    p;
}

