FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      chemistryProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

chemistryType
{
    chemistrySolver   ode;
    chemistryThermo   psi;
}

chemistry       on;

initialChemicalTimeStep 1e-10;

EulerImplicitCoeffs
{
    cTauChem        1;
    equilibriumRateLimiter off;
}

odeCoeffs
{
    solver          rodas23;
    absTol          1e-12;
    relTol          1e-4;
}

reduction
{

    active          on;    // Activate reduction

    log             on;    // Switch logging of the reduction statistics and performance

    tolerance       0.0001;

    method          pDAC;   // Dynamic Adactive Chemistry (DAC)

// this is an important set of parameters for chemistry reduction. 
// All species and reactions that strongly (depends on the tolerance) affect 
// the production(or consumption) of these species will be included.
    initialSet
    {
        CO              ;
        CH4             ;
        HO2             ;
    }

// For DAC, option to automatically change the 
// Search initiating set (SIS) switch from HO2 to H2O
// and CO to CO2, + disable fuel
    automaticSIS    off;

// When automaticSIS, the method needs to know the fuel
    fuelSpecies
    {
        CH4             1;
    }
}

tabulation
{
    // Activate tabulation
    active      on;

    // Switch logging of the tabulation statistics and performance
    log         on;

    printProportion         off;

    printNumRetrieve        off;

    // Tolerance used for retrieve and grow
    tolerance               1e-4;

    // ISAT is the only method currently available
    method                  pISAT;

    // Scale factors used in the definition of the ellipsoid of accuracy
    scaleFactor
    {
        otherSpecies        1;
        Temperature         2400;
        Pressure            1e6;
        deltaT              1;
    }

    // Maximum number of leafs stored in the binary tree
    maxNLeafs               200000;

    //leaves will be deleted if they have not been used by this number of timestep.
    chPMaxLifeTime          20;

    // Maximum number of growth allowed on a leaf
    maxGrowth               20000;

    // Number of time steps between analysis of the tree to remove old
    // chemPoints or try to balance it
    checkEntireTreeInterval 500;

    // Parameters used to decide whether to balance or not if the tree's depth
    // is larger than maxDepthFactor*log2(nLeafs) then balance the tree
    maxDepthFactor          2;

    // Try to balance the tree only if the size of the tree is greater
    minBalanceThreshold     30;

    // Activate the use of a MRU (most recently used) list
    MRURetrieve             false;

    // Maximum size of the MRU list
    maxMRUSize              0;

    // Allow to grow points
    growPoints              true;

    // When mechanism reduction is used, new dimensions might be added
    // maxNumNewDim set the maximum number of new dimensions added during a
    // growth
    maxNumNewDim            10;

    // Secondary search in binary tree
    max2ndSearch            0;

    // Clean the binary tree when it is full. 
    // if MRU is not activatied, cleaning will delete the whole binary tree
    cleanAfterFull          false;

    // Used to do tests. Direct integration will be done after retrieve
    // Results are comparied and ensamble results are stored in "Summary"
    TestSwitch              false;//true;
}

