FoamFile
{
    version         2.0;
    format          ascii;

    root            "";
    case            "";
    instance        "";
    local           "";

    class           dictionary;
    object          sprayProperties;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
solution
{
    //- FV fields to particle interpolation
    interpolationSchemes
    {
        U           cellPoint;
        DEff	    cellPoint;
        rho         cellPoint;
        gradRho     cellPoint;
        f		    cellPoint;
        p		    cellPoint;
    }
}

particleManagement
{
    //- Particle number control
    numCtlOn         on;

    Npc 10;
    Nlo 8;
    Nhi 14;
}

subModels
{
    InflowBoundaryModel          FreeStream;
    //InflowBoundaryModel          NoInflow;

    compositionModel singlePhaseMixture;
    // compositionModel none;

    radiationModel OpticallyThinRadiation;
    //radiationModel none;

    sootModel           none;

    OpticallyThinRadiationCoeffs
    {
        TRef        300;    // Reference temperature - default 300K
    }

    printMoleFractions false;

    thermoPhysicalCouplingModel FlameletCurves;
    //thermoPhysicalCouplingModel KernelEstimation; // Under development
    
    KernelEstimationCoeffs
    {
        fLow                0.03;   //lower flamability limit
        fHigh               0.19;   //upper flamability limit
        fm                  0.02;   //same as in mixing model
        
        condVariable        f;
        dfMax               0.0075; //Maximum distance in f space allowed to do extrapolation            
        C2                  0.1;    //used to control resolution
    }
    
    mixingModel		MMCcurl;
    // mixingModel none;
 
    MMCcurlCoeffs
    {
        //- Parameters ri and fm as per Eq.(29) Cleary & Klimenko, Phys Fluids 23, 115102, 2011
        ri 		    6.7e-3;

        Ximi
        {
            fm              0.03;    
        }

        localnessLimited    false;

        fLowMixOnMaster     0.01;
        fHighMixOnMaster    1;

        fullSort            false;
        aISO                true; 
        meanTimeScale       true; //true:mean false:max

        pairingMethod       global;
    }

    reactionModel finiteRateParticleChemistry;

    // Dynamic load balancing (finiteRateChem only)
    balanceReactionLoad false; 

    finiteRateParticleChemistryCoeffs
    {
        zLower              0.1;
        zUpper              0.9;
    }
}

//- ThermophysicalModel coupling
thermophysicalCoupling
{
    enabled             true;

    //- List of species for which equivalent
    //  mass fraction solutions are obtained
    //  on the FV grid
    CH4;
    O2;
    CO2;
    H2O;
    N2;

    condVariable        z;
    
    primarySpecies      CO2;
    
    tauRelaxBlending    false;
    tauRelaxStart       1000;
    tauRelaxDelta       2;
    tauRelax            10;
    tauUnits            timestep;
}

// Calculate stochastic field statistics on the fly
eulerianStatistics
{
    enabled false;
}

sootData
{
    sootingFlame        true;

    //min wt of solid particle, 15;10;7;5;4;2;1 nm : >=BIN13 11 10 9 8 5 2   
    sootMinMolWt        (4128065  588019.0  235048.0 97022 41616 4513 500); 

    sootSolidDensity    1800.0; // constant density of soot
    MinKnScaledMix      10; //min Kn of species for non-scaled mixing
    IntermittencyfV     0.1; // ppb

}


particleSampling
{
    enabled             false;
}
