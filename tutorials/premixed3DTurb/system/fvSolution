FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    rho
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-012;
     //   relTol          0.0;
    }

    rhoFinal
    {
        $rho;
    }

    p
    {
        solver           PCG;
        preconditioner   DIC;
        tolerance        1e-012;
        relTol           1e-03;
    }

    pFinal
    {
        $p;
        tolerance        1e-012;
        relTol           0.0;
    }

    "(U|h|Yi|Xii)"
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-012;
       // relTol          0.0;
    }

    "(U|h|Yi|Xii)Final"
    {
        $U;
    }

}

PIMPLE
{
    momentumPredictor yes;
    nOuterCorrectors  2;
    nCorrectors     2;
    nNonOrthogonalCorrectors 0;
}

PDFMETHOD
{
  pdfMethodOn       true;
  iniReleaseOn      true;
  nSet              1;
  pdfScatPlotOn     false;
  pdfScatPlotSize   5000;  
}



