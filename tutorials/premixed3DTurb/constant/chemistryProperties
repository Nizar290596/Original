FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      chemistryProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

chemistry       on;

chemistryType
{
    chemistrySolver   ode;
    chemistryThermo   psi;
}

initialChemicalTimeStep 1e-10;

odeCoeffs
{
    solver          Euler;
    absTol          1e-12;
    relTol          0.01;
}

reduction
{
    active          off;
    method          pNone;
}

tabulation
{
    active          off;
    method          pNone;
}



