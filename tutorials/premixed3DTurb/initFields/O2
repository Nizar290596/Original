FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      O2;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 0 0 0 0];

internalField   uniform  0.2251;

boundaryField
{

     BOTTOM                                                                                      
     {
         type            cyclic;
     }
     TOP
     {
         type            cyclic;
     }
     SOUTH 
     {
         type            cyclic;
     }
     NORTH
     {
         type            cyclic;
     }
     OUTLET
     {
         type            zeroGradient;
     }
     INLET
     {
        type            fixedValue;
        value           uniform 0.2251;
     }
     defaultFaces
     {
         type            empty;
     }

}


