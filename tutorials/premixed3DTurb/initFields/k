FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 8.4887;

boundaryField
{
    BOTTOM
    {
        type            cyclic;
    }
    TOP
    {
        type            cyclic;
    }
    SOUTH
    {
        type            cyclic;
    }
    NORTH
    {
        type            cyclic;
    }
    INLET
    {
        type            fixedValue;
        value           uniform 8.4887;
    }
    OUTLET
    {
        type            zeroGradient;
    }
}


