FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform 100000;

boundaryField
{
BOTTOM                                                                                      
     {
         type            cyclic;
     }
     TOP
     {
         type            cyclic;
     }
     SOUTH 
     {
         type            cyclic;
     }
     NORTH
     {
         type            cyclic;
     }
    INLET
    {
        type            zeroGradient;
    }
    OUTLET
    {
       type            waveTransmissive;
       value           uniform 100000;
       gamma           1.4; 
       lInf            0.1;             //a measure of how far away the far-field condition should be
       fieldInf        100000;            //the far-field value to be applied to p
    }
}


