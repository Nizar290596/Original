FoamFile
{
    version     2.0;
    format      binary;
    class       dictionary;
    location    "constant";
    object      thermophysicalProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

thermoType
{
    type            hePsiThermo;
    mixture         reactingMixture;
    transport       sutherland;
    thermo          janaf;
    energy          sensibleEnthalpy;
    equationOfState perfectGas;
    specie          specie;
}

inertSpecie N2;

liquids
{
  C2H5OH
  {
    defaultCoeffs   yes;
  }
}

solids
{
}

chemistryReader      chemkinReader;

// Single-step mechanism (5 species, 1 reaction)
CHEMKINFile       "$FOAM_CASE/constant/chemkin/chem.inp";
CHEMKINThermoFile "$FOAM_CASE/constant/chemkin/therm.dat";


CHEMKINTransportFile "$FOAM_CASE/constant/chemkin/transportProperties";

