FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      turbulenceProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

simulationType  LES;

LES
{
    LESModel        sigma;

    turbulence      on;

    printCoeffs     on;

    delta           cubeRootVol;

    cubeRootVolCoeffs
    {
        deltaCoeff      1;
    }

    SmagorinskyCoeffs
    {
        Ce              1.048;  // Cs=0.168
//      Ce            8.30584;  // Cs=0.1
        Ck              0.094;
    }

    itvSigmaCoeffs
    {
        Ck               0.094;
        Csigma            1.50;
    }

}

