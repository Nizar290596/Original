FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application              mmcFoam;
startFrom              startTime;
startTime                      0;
stopAt                   endTime;
endTime                    2e-05;  // 40*tj
deltaT                     2e-07;
writeControl   adjustableRunTime;
writeInterval              2e-06;  // 10*tj
purgeWrite                     0;
writeFormat               ascii;
writePrecision                 8;
runTimeModifiable            yes;
adjustTimeStep               yes;
maxCo                        0.4;

