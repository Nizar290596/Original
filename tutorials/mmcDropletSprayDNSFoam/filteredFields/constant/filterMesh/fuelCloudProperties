FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      fuelCloudProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //



// LAGRANGIAN SOLVER SETTINGS =================================================
solution
{

  // General settings ---------------------------------------------------------
  active                     true;  // Activate/deactivate the particle cloud
  coupled                    true;  // Coupling (droplets->finite-volume field + stochastic particles)
  transient                  true;  // transient or steady-state Lagrangian solver (unused)
  cellValueSourceCorrection false;  // Correct cell values after phase change (unused)

  // Integration schemes for Lagrangian particle variables --------------------
  // (Euler/analytical)
  integrationSchemes
  {
    U  Euler;
    T  EulerExplicit;
    M  Euler;
  }

  // Interpolation schemes for the FV-field values ----------------------------
  // (cell/cellPoint/cellPointFace/cellPointWallModified/cellPatchConstrained/pointMVC)
  interpolationSchemes
  {
    rhoFiltered     cellPoint;
    UFiltered       cellPoint;
    thermo:mu       cellPoint;
    T               cellPoint;
    p               cellPoint;
    f               cellPoint;
    fGradSqr        cellPoint;
    Cp              cellPoint;
    kappa           cellPoint;
    C2H5OH          cell;
    CO2             cell;
    O2              cell;
    H2O             cell;
    N2              cell;  
    averagedField_C2H5OH          cell;
    averagedField_CO2             cell;
    averagedField_O2              cell;
    averagedField_H2O             cell;
    averagedField_N2              cell; 

  }

  // Treatment of source terms ------------------------------------------------
  // (explicit/semiImplicit)
  sourceTerms
  {
    schemes
    {
      rho        explicit 1;
      U          explicit 1;
      Yi         explicit 1;
      h          explicit 1;
    }
  }

}


// PARTICLE PROPERTIES ========================================================
constantProperties
{
  T0 315.00;  // Initial Temperature [K]
  Cp0 2460;
  Tvap0 351.5; //Evaporation Temperature [K]
}



// SUBMODELS ==================================================================
subModels
{

  // Injection model ----------------------------------------------------------
  injectionModels
  {
    model1
    {
      type                     manualInjectionMMC;  // manualInjection/patchInjection/none
      parcelBasisType                       fixed;  // (number/mass/fixed)
      massTotal                                 1;  // Total mass to inject [kg] (unused if parcelBasisType=fixed)
      nParticle                                 1;  // Number of particles per parcel [-] (unused if parcelBasisType=mass)
      massFlowRate                              0;  // unused
      SOI                                       0;  // Start time of injection [s]
      positionsFile          "fuelCloudPositions";  // File with positions (if manualInjection)
      initialVelocityType                    cell;  // unused
      U0                                  (0 0 0);  // Initial parcel/particle velocity [m/s] (will be overwritten)
      UName                           "UFiltered";  // Specify the name of the velocity field


      // Parcel size distribution model ---------------------------------------
      // (fixedValue/uniform/normal/exponential/RosinRammler/multiNormal/general)
      sizeDistribution
      {
        type fixedValue;
        fixedValueDistribution
        {
          value    3.00e-05;
        }
      }
    }
  }

    // Droplet species component
    dropletComponent C2H5OH;

    particleForces
    {
        sphereDrag      ;
    }


    dispersionModel none;
    patchInteractionModel standardWallInteraction;
    stochasticCollisionModel none;
    //heatTransferModel none;
    surfaceFilmModel none;
    //radiation       none;
    standardWallInteractionCoeffs
    {
        type            rebound;
    }
    
    LiquidPropertiesModel OFLiquidProperties;

    // When the OpenFOAM liquid properties is selected, select
    // here the correct liquid name.
    // See also: ${WM_PROJECT_DIR}/src/thermophysicalProperties/liquidProperties
    OFLiquidPropertiesCoeffs
    {
        fluidName   C2H5OH;
    }


    UDFCoeffs
    {
        saturationPressure
        {
            type            coded;
            code            #{
               std::vector<scalar> a {59.796, -6595.0, -5.0474, 6.3e-07, 2.0};  // C2H5OH
               return ( std::exp(a[0]+a[1]/x+a[2]*std::log(x)+a[3]*std::pow(x,a[4])) );
           #};
        }
        saturationTemperature
        {
            type            coded;
            code            #{

                            std::vector<scalar> a {3.5154e+02, 2.5342e+01, 2.2231e+00, 2.0784e-01};  // C2H5OH
                            scalar P1 = log(x/101325.0);
                            return ( a[0]+a[1]*P1+a[2]*P1*P1+a[3]*P1*P1*P1 );
           #};
        }

        binaryDiffusionCoefficient 5.765e-06;
        latentHeat
        {
            type            coded;
            code            #{
                scalar Tc = 516.25;
                scalar T1 = x/Tc;
                std::vector<scalar> a {958345.091059, -0.4134, 0.75362, 0.0};  // C2H5OH
                return ( a[0]*pow(1.0-T1,a[1]+a[2]*T1+a[3]*T1*T1) );
           #};
        }
        liquidHeatCapacity
        {
            type            coded;
            code            #{
               std::vector<scalar> a {2052.57331394213, -0.121990926653498, -0.00714146172046278, 5.20523562482363e-05, 0.0};  // C2H5OH
               return ( a[0]+a[1]*x+a[2]*x*x+a[3]*x*x*x+a[4]*x*x*x*x );
           #};
        }
        liquidAbsoluteEnthalpy
        {
            type            coded;
            code            #{
            std::vector<scalar> a {-6752827.25039109, 2052.57331394213, -0.060995463326749, -0.00238048724015426, 1.30130890620591e-05};  // C2H5OH
            return ( a[0]+a[1]*x+a[2]*x*x+a[3]*x*x*x+a[4]*x*x*x*x );
           #};
        }

        rhoL
        {
            type            coded;
            code            #{
                std::vector<scalar> a {70.1308387, 0.26395, 516.25, 0.2367, 0.0};  // C2H5OH
                const scalar T = std::min(a[2],x);
                return ( a[0]/pow(a[1],1.0+pow(1.0-T/a[2],a[3])) );
            #};
        }
    }
    

    dropletToMMCModel nearestNeighbor;
    nearestNeighborCoeffs
    {
        useSPProps                 false;  // false: fLES is used; true: zSP is used
        lambda_x                     true;
        lambda_f                     false;
        lambda_T                     true;
        ri                    2.5856e-04;
        fm                        0.0072;
        Tm                          40.0;
    }



    sourceDistribution PSI;        // Default is particle-source-in-cell model (PSI)
                                    // (Optional) activate distributed

    // If distSourceModel is active the sourceDistrbutionCoeff need 
    // to provide the averaging volume
    distributedCoeffs 
    {
        // Set size of the box to 10 times the droplet diameter
        type       box;
        length     300E-6;
    }

}



// STATISTICS AND CO ==========================================================
eulerianStatistics
{
  enabled        false;
}

particleSampling
{
    enabled             true;

    collated            true;

    sampleInterval        20;

    particleSampleProbes
    {
        zD01
        {
            type        particleProbeBox;
            p1          (-1 -1 -1);
            p2          (1 1 1);
        }
    }
}


