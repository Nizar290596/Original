FoamFile
{
    version     2.0;
    format      binary;
    class       dictionary;
    location    "constant";
    object      chemistryProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

chemistry                   on;

chemistryType
{
    chemistrySolver        ode;
    chemistryThermo        psi;
}

initialChemicalTimeStep  1e-08;

odeCoeffs
{
    solver              seulex;
    absTol               1e-14;
    relTol               1e-04;
}

reduction
{
    active          off;
    method          pNone;;
}

tabulation
{
    active          off;
    method          pNone;
}



