FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      kinematicCloudProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solution
{
    active          true;
    coupled         true;
    transient       yes;
    cellValueSourceCorrection on;

    sourceTerms
    {
        schemes
        {
            rho             explicit 1;
            U               explicit 1;
            Yi              explicit 1;
            h               explicit 1;
            radiation       explicit 1;
        }
    }

    interpolationSchemes
    {
        rho             cell;
        U               cellPoint;
        thermo:mu       cell;
        T               cell;
        p               cell;
        f               cell;
        fGradSqr        cell;
    }

    integrationSchemes
    {
        U               Euler;
        T               Euler;
        M               Euler;
    }
}


constantProperties
{
    rho0            1200.00; // [1] [kg/m3]
    T0              298.00;
    CpD             1254.00; // [1] [J/kgK]    // Fragmentation and diffusion model for coal pyrlysis
    epsilon0        1.0; 
    f0              0.5;
    Le              1.0; 
    Sc              0.7;
    latentHeat      0.0; // [J/kg] // very small

    constantVolume  false;
}


// Calculate fuel particle statistics on the fly
eulerianStatistics
{
    enabled false;
    
    axisymmetric false;
    symmetryPlane zx;

    U|d_z
    (
    (0e-6       60e-6)
    );

    fGas; 
    fSurf; 
    TGas; 
    TSurf;
}




subModels
{
    particleForces
    {
/*        sphereDrag;*/
/*        gravity;*/
    }

    injectionModels
    {
        model1
        {
            type            patchInjection;     // injection type
            SOI             5e-05;              // [second]
            massTotal       1.49;               // [kg]
            parcelBasisType mass;               //
            patchName       mainJet;            // patch of injection
            duration        10000;              // [second]
            parcelsPerSecond 1e8;               // number of parcel per second
            U0              (0 0 6.3662);       // [m/s]
            flowRateProfile constant 1;         // 
            sizeDistribution                    // parcel diameter distribution
            {
                type        general;
                generalDistribution
                {
                    distribution                // size distribution of particle
                    (
                        ( 5e-06      0.2408)
                        (10e-06      15.0883)
                        (15e-06      15.8106)
                        (20e-06      17.8170)
                        (25e-06      11.7978)
                        (30e-06      11.7978)
                        (35e-06      11.3162)
                        (40e-06      8.8283)
                        (45e-06      2.4880)
                        (50e-06      2.8090)
                        (55e-06      0.7223)
                        (60e-06      1.2841)
                    );
                }
            }
        }
    }




    pyrolysisModel  ArrheniusModel;

    ArrheniusModelCoeffs
    {
        //- Pyrolysis rate coefficients
//        gamma                2.4E4;         //-[2] pre-exponential factor
//        Ta                   4450.3;        //-[2] activation temperature (k)
//        initial              ???;           //-[2] initial volatile fraction from coal

        gamma                  4.474E3;       //-[3] pre-exponential factor
        Ta                     2307.9;        //-[3] activation temperature (k)
        initial                0.4089;        //-[3] initial volatile fraction from coal

        //- composition of immediate pyrolysis product
        CH4                    1.0;
    }

}

