FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     mmcFoam;

startFrom       latestTime; //startTime;

startTime       0;

stopAt          endTime;

endTime         2;

deltaT          1e-06;

writeControl    timeStep;

writeInterval   50000;

writeFormat     ascii;

writePrecision  12;

writeCompression off;

timeFormat      general;

timePrecision   8;

runTimeModifiable true;

adjustTimeStep  yes;

maxCo           0.5;



