FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      setFieldsDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

defaultFieldValues
(
    volVectorFieldValue U (0 0 0.5)
);

regions
(
    cylinderToCell
    {
        p1 (0 0 0);

        p2 (0 0 0.22);

        radius 3.0e-3;

        fieldValues
        (            
            volVectorFieldValue U (0 0 12)
        );
    }
);


