FoamFile
{
    version     2.0;
    format      binary;
    class       dictionary;
    location    "constant";
    object      thermophysicalProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

thermoType
{
    type            hePsiThermo;
    mixture         reactingMixture;
    transport       sutherland;
    thermo          janaf;
    energy          sensibleEnthalpy;
    equationOfState perfectGas;
    specie          specie;
}

inertSpecie N2;

CHEMKINFile          "$FOAM_CASE/constant/chemistry/chem.inp";

CHEMKINThermoFile    "$FOAM_CASE/constant/chemistry/therm.dat";

CHEMKINTransportFile "$FOAM_CASE/constant/chemistry/transportProperties";

