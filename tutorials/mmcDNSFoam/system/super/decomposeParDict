FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      decomposeParDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

numberOfSubdomains 24;

method       hierarchical;

hierarchicalCoeffs
{
    n               (2 6 2);
    delta           1e-12;
    order           xyz;
}

