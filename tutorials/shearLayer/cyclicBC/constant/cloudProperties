FoamFile
{
    version         2.0;
    format          ascii;

    root            "";
    case            "";
    instance        "";
    local           "";

    class           dictionary;
    object          cloudProperties;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
solution
{
    //- FV fields to particle interpolation
    interpolationSchemes
    {
        U           cellPoint;
        DEff	    cellPoint;
        rho         cellPoint;
        gradRho     cellPoint;
        f		    cellPoint;
        p		    cellPoint;
    }
}

particleManagement
{
    //- Particle number control
    numCtlOn        off;

    Npc 50;
    Nlo 30;
    Nhi 80;
}

subModels
{
    //InflowBoundaryModel          FreeStream;
    InflowBoundaryModel          NoInflow;

    compositionModel singlePhaseMixture;
    // compositionModel none;

    sootModel none;

    //radiationModel OpticallyThinRadiation;
    radiationModel none;
    OpticallyThinRadiationCoeffs
    {
        TRef     300;
    }

    printMoleFractions false;

    thermoPhysicalCouplingModel FlameletCurves;
    //thermoPhysicalCouplingModel KernelEstimation; // Under development
    
    KernelEstimationCoeffs
    {
        fLow                0.03;   //lower flamability limit
        fHigh               0.19;   //upper flamability limit
        fm                  0.03;   //same as in mixing model
        
        condVariable        f;
        dfMax               0.0075; //Maximum distance in f space allowed to do extrapolation            
        C2                  0.1;    //used to control resolution
    }

    mixingModel		MMCcurl;
    //mixingModel none;
 
    MMCcurlCoeffs
    {
        //- Parameters ri and fm as per Eq.(29) Cleary & Klimenko, Phys Fluids 23, 115102, 2011
        ri  		    6.7e-3;

        Ximi
        {
            fm              0.03;
        }

        localnessLimited    false;

        fLowMixOnMaster     0.01;
        fHighMixOnMaster    1;

        fullSort            false;
        aISO                true; 
        meanTimeScale       true; //true:mean false:max

        pairingMethod       global;
    }

    reactionModel none;

    finiteRateNewtonLinODEChemistryCoeffs
    {
        zLower              0.1;
        zUpper              0.9;
    }
}

//- ThermophysicalModel coupling
thermophysicalCoupling
{
    enabled    true;

    //- List of species for which equivalent
    //  mass fraction solutions are obtained
    //  on the FV grid
    O2;
    N2;
    CO;
    H2;

    condVariable        z;
    
    primarySpecies      T;
    
    tauRelaxBlending    false;
    tauRelaxStart       1000;
    tauRelaxDelta       2;
    tauRelax            10;
    tauUnits            timestep;
}

// Calculate stochastic field statistics on the fly
eulerianStatistics
{
    enabled false;
}

particleSampling
{
    enabled             false;
}
