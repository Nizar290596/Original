/*	arc 29 30 (-0.0707106781 0.0707106781   $Length)*/
/*	arc 30 31 (-0.0707106781 -0.0707106781  $Length)*/
/*	arc 31 28 (0.0707106781 -0.0707106781  $Length)*/


);

// MESH resolution and stretching

Nradsqr 3;
Ncent 3;
Nax 64;
Nradnoz 1;
NradNozzledge 2;
NradCoFlow 8;
sgrad 1;
sgradco 2;

 
// block definitions
blocks
(
    // Square Jet
    hex ( 1 2 3 4 18 19 20 21 ) ($Nradsqr $Ncent $Nax) simpleGrading (1 1 1)  // jet
 
    //  Circular Jet	
       	// x+, y+         // radial  circumferential  axial   
	    hex ( 1 5 6 2 18 22 23 19) ($Nradnoz $Ncent $Nax) simpleGrading (1 1 1)  
