	// x+ y-
	    hex (4 8 5 1 21 25 22 18) ($Nradnoz $Ncent $Nax) simpleGrading (1 1 1)    
    // pilot
	// x+, y+         // radial  circumferential  axial
	    hex (5 9 10 6 22 26 27 23)   ($NradNozzledge $Ncent $Nax) simpleGrading ($sgrad 1 1)  
	// x- y+
	    hex (6 10 11 7 23 27 28 24)  ($NradNozzledge $Ncent $Nax) simpleGrading ($sgrad 1 1)  
	// x- y-
	    hex (7 11 12 8 24 28 29 25) ($NradNozzledge $Ncent $Nax) simpleGrading ($sgrad 1 1)  
	// x+ y-
	    hex (8 12 9 5 25 29 26 22)  ($NradNozzledge $Ncent $Nax) simpleGrading ($sgrad 1 1)  


    // coflow 
	// x+, y+
	   hex (9 13 14 10 26 30 31 27)   ($NradCoFlow $Ncent $Nax) simpleGrading ($sgradco 1 1)  
	// x- y+
	   hex (10 14 15 11 27 31 32 28)  ($NradCoFlow $Ncent $Nax) simpleGrading ($sgradco 1 1)  
	// x- y-
	   hex (11 15 16 12 28 32 33 29) ($NradCoFlow $Ncent $Nax) simpleGrading ($sgradco 1 1)  
	// x+ y-
   	   hex (12 16 13 9 29 33 30 26)  ($NradCoFlow $Ncent $Nax) simpleGrading ($sgradco 1 1)  




);


