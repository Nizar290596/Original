FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application       mmcSprayFoam;

startFrom         latestTime; //startTime;

startTime         0;

stopAt            endTime;

endTime           4.0e-06;  // Tau_ft = 0.0153 sec

deltaT            1e-06;

writeControl      timeStep;

writeInterval     1000;

writeFormat       ascii;

writePrecision    12;

writeCompression  on;

timeFormat        general;

timePrecision     8;

runTimeModifiable true;

adjustTimeStep    yes;

maxCo             0.4;


