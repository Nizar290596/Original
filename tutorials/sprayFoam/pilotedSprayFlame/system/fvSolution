FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    rho
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-08;
        minIter         3;
        relTol          0.001;
    }

    rhoFinal
    {
        $rho;
        tolerance       1e-10;
        relTol          0;
    }

    p
    {
        solver          GAMG;
        tolerance       1e-06;
        relTol          0.01;
        minIter         3;
        smoother        DIC;
        nPreSweeps      1;              
        nPostSweeps     2;              
        nFinestSweeps   2;              
        cacheAgglomeration on;          
                                        
        nCellsInCoarsestLevel 1200;     
                                        
        agglomerator    faceAreaPair;   
        mergeLevels     1;
    }

    pFinal
    {
        $p;
        smoother        DICGaussSeidel;
        tolerance       1e-06;
        relTol          0;
    
    }

    "(U|h|k|nuTilda|f|Xii|hEqvE|Yi)"
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-08;
        minIter         3;
        relTol          0.01;
    }

    "(U|h|k|nuTilda|f|Xii|hEqvE|Yi)Final"
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-08;
        relTol          0;
    }
}

PIMPLE
{
    momentumPredictor yes;
    nOuterCorrectors 2;
    nCorrectors     1;
    nNonOrthogonalCorrectors 1;
}

PDFMETHOD
{
  pdfMethodOn       yes;
  nSet              1;
  pdfScatPlotOn     no;
  pdfScatPlotSize   5000;  // No of scatter data on each processor
}

FUELPARTICLE
{
  fuelParticleOn     yes;
  nSet               1;
  fuelScatPlotOn     no;
  fuelScatPlotSize   5000;  // No of scatter data on each processor
}

