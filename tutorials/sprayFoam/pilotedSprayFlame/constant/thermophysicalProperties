FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      thermophysicalProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

thermoType
{
    type            hePsiThermo;
    mixture         reactingMixture;
    transport       sutherland;
    thermo          janaf;
    energy          sensibleEnthalpy;
    equationOfState perfectGas;
    specie          specie;
}

inertSpecie N2;
fuel        CH3COCH3;

chemistryReader  chemkinReader;
newFormat        yes;

CHEMKINFile         "$FOAM_CASE/acetone/grimech.30";
CHEMKINThermoFile    "$FOAM_CASE/acetone/therm.dat";
CHEMKINTransportFile "$FOAM_CASE/acetone/transportProperties";
