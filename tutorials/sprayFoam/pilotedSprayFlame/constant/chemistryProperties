FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      chemistryProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

chemistryType
{
    chemistrySolver   ode;
    chemistryThermo   psi;
}

chemistry                  on;
initialChemicalTimeStep 1e-10;

odeCoeffs
{
    solver    seulex;
    absTol    1e-8;
    relTol    1e-2; 
}

reduction
{
    active          off;
    method          pNone;
}

tabulation
{
    active          off;
    method          pNone;
}

