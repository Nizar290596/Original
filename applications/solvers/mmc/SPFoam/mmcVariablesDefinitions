FoamFile
{
    version         2.0;
    format          ascii;

    root            "";
    case            "";
    instance        "";
    local           "";

    class           dictionary;
    object          mmcVariablesDefinitions;
}   
    
variables
{
    z
    {
        name            z;
        couplingName    z;
        passive         true;
        mixStep         1;
        MMCType         couplingVar;
    }

    // Progress variable — primary conditioning scalar, mixed in Stage 1.
    // Set passive false when the Eulerian c field is coupled to particles.
    c
    {
        name            c;
        couplingName    c;
        passive         false;
        mixStep         1;
        MMCType         couplingVar;
    }

    // Shadow-position reference variables (Stage 1 pairing).
    sPx
    {
        name            sPx;
        MMCType         referenceVar;
        referenceType   sde;
    }

    sPy
    {
        name            sPy;
        MMCType         referenceVar;
        referenceType   sde;
    }

    sPz
    {
        name            sPz;
        MMCType         referenceVar;
        referenceType   sde;
    }

    // Bounded Ornstein-Uhlenbeck variable (Stage 2 second conditioning).
    // Evolves as:  dω = -θ·ω·dt + sqrt(2θ)·dW,  clipped to [-wMax, +wMax].
    // The modified progress variable phi* = c * exp(beta * wOU) is used for
    // Stage 2 pairing in the sparsePremixedMMCcurl mixing model.
    wOU
    {
        name            wOU;
        MMCType         referenceVar;
        referenceType   sde;
    }
}
